# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in values before running
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=sip
POSTGRES_PASSWORD=sippassword
POSTGRES_DB=staffing
DATABASE_URL=postgresql://sip:sippassword@localhost:5432/staffing

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── DuckDB ────────────────────────────────────────────────────────────────────
DUCKDB_PATH=./data/analytics.duckdb

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./data/mlruns

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_COOKIE_SECRET=CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
